{
  "name": "open-browser-use-monorepo",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "coverage": "pnpm coverage:sdk && pnpm coverage:extension && pnpm coverage:rust",
    "coverage:extension": "pnpm --filter @open-browser-use/extension coverage",
    "coverage:rust": "sh scripts/coverage-rust.sh",
    "coverage:sdk": "pnpm --filter @open-browser-use/sdk coverage",
    "assemble:payload": "node scripts/assemble-payload.mjs",
    "generate:wire-methods": "node scripts/generate-wire-methods.mjs",
    "check:wire-methods": "node scripts/generate-wire-methods.mjs --check",
    "generate:error-codes": "node scripts/generate-error-codes.mjs",
    "check:error-codes": "node scripts/generate-error-codes.mjs --check",
    "generate:control-vocab": "tsx scripts/generate-control-vocab.mjs",
    "check:control-vocab": "tsx scripts/generate-control-vocab.mjs --check",
    "generate:descriptor-vocab": "tsx scripts/generate-descriptor-vocab.mjs",
    "check:descriptor-vocab": "tsx scripts/generate-descriptor-vocab.mjs --check",
    "check:state-continuity": "cargo test -p obu-host --test e2e_node_repl_to_webextension fake_webextension_node_repl_preserves_shopping_state_across_cells",
    "make:extension-store-artifact": "node scripts/make-extension-store-artifact.mjs",
    "fetch:node-runtime": "node scripts/fetch-node-runtime.mjs",
    "make:curl-artifact": "node scripts/make-curl-artifact.mjs",
    "smoke:agent-adapters": "node scripts/agent-adapter-smoke.mjs",
    "smoke:cli-runtime-deps": "node scripts/cli-runtime-deps-smoke.mjs",
    "smoke:curl-install": "node scripts/curl-install-smoke.mjs",
    "smoke:install-refresh-safety": "node scripts/install-refresh-safety-smoke.mjs",
    "smoke:cargo-dist": "node scripts/cargo-dist-smoke.mjs",
    "smoke:mcp-stdio-clean": "node scripts/mcp-stdio-clean-smoke.mjs",
    "smoke:mcp-client-compat": "cargo test -p obu-node-repl --test mcp_stdio mcp_stdio_client_compat_profiles_preserve_structured_content_resources_and_progress",
    "test:oracles": "node scripts/validate-oracles.mjs",
    "smoke:payload": "node scripts/payload-self-check.mjs",
    "smoke:p4-release-readiness": "node scripts/p4-release-readiness-smoke.mjs",
    "smoke:npm-pack": "node scripts/npm-pack-smoke.mjs",
    "stage:npm": "node scripts/stage-npm-packages.mjs",
    "smoke:package-static": "node scripts/package-local-smoke.mjs --target all --static",
    "smoke:setup-local-spine": "node scripts/setup-local-spine-smoke.mjs",
    "smoke:setup-webext": "node scripts/setup-webext-e2e.mjs",
    "smoke:cdp-dirty-form-live": "OBU_E2E_AUTO_INSTALL=1 OBU_CDP_E2E_TEST_FILTER=cdp_dirty_form_beforeunload_does_not_block_navigation_close_or_finish_turn bash scripts/p2-e2e.sh",
    "smoke:webext-dirty-form-live": "OBU_WEBEXT_E2E_TEST_FILTER=webextension_dirty_form_beforeunload_survives_reattach_and_finish_turn bash scripts/p3-webext-e2e.sh",
    "smoke:npm-wrapper": "node scripts/npm-wrapper-resolver-smoke.mjs",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
