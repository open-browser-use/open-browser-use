{
  "manifest_version": 3,
  "name": "open-browser-use",
  "description": "Control Chromium-family browsers through open-browser-use.",
  "version": "0.1.0",
  "key": "",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "open-browser-use",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "cursor.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "permissions": [
    "nativeMessaging",
    "debugger",
    "tabs",
    "tabGroups",
    "scripting",
    "storage",
    "history",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
